@article{burns_eye_2019,
	title = {In the eye of the storm? {The} {European} {Parliament}, the environment and the {EU}’s crises},
	volume = {41},
	issn = {0703-6337},
	shorttitle = {In the eye of the storm?},
	url = {https://doi.org/10.1080/07036337.2019.1599375},
	doi = {10.1080/07036337.2019.1599375},
	abstract = {The European Parliament (EP) has a long-established reputation as an ‘environmental champion’. Yet, environmental policy has potentially been profoundly and negatively affected by the conglomerate of crises that has beset the European Union (EU) since the late 2000s. There has been a swing to the right within the Parliament in recent elections, and the entry of a range environmentally sceptic states to the EU, which may have led to weakening policy ambition. This article uses a mix of quantitative and qualitative data to analyse whether there has been a shift in the EP’s treatment of legislation, such that it has tried to weaken the policy ambition of proposals since the late 2000s. The analysis finds limited evidence of a general trend to deliberately water down legislation, and overall suggests that despite a less favourable policy context, the EP still can and does exercise a positive influence over EU environmental policy.},
	number = {3},
	urldate = {2024-09-24},
	journal = {Journal of European Integration},
	publisher = {Routledge},
	author = {Burns, Charlotte},
	month = apr,
