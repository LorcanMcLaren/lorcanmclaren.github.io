	note = {arXiv:2007.11154 [cs, eess]},
	keywords = {Computer Science - Computer Vision and Pattern Recognition, Computer Science - Sound, Electrical Engineering and Systems Science - Audio and Speech Processing},
	file = {Palanisamy et al. - 2020 - Rethinking CNN Models for Audio Classification.pdf:/Users/lorcanmclaren/Zotero/storage/4RXUAN92/Palanisamy et al. - 2020 - Rethinking CNN Models for Audio Classification.pdf:application/pdf},
}

