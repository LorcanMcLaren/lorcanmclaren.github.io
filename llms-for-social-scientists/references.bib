	keywords = {Climate, Economic Development: Agriculture, Energy, Environment, Environmental Economics: Government Policy Q58, Global Warming Q54, International Agreements and Observance, International Organizations F53, Natural Disasters and Their Management, Natural Resources, NGOs, Nonprofit Institutions, Other Primary Products O13, Social Entrepreneurship L31},
	pages = {337--363},
