	keywords = {Construal level theory, Mental construal, Temporal distance, Time perception},
	pages = {143--149},
	file = {Full Text:/Users/lorcanmclaren/Zotero/storage/9MBHQZSE/Liberman et al. - 2007 - The effect of level of construal on the temporal d.pdf:application/pdf;ScienceDirect Snapshot:/Users/lorcanmclaren/Zotero/storage/VSXIVINQ/S0022103106000023.html:text/html},
}

@book{dryzek_politics_2021,
	address = {Oxford},
	edition = {4th edition},
	title = {The {Politics} of the {Earth}: {Environmental} {Discourses}},
