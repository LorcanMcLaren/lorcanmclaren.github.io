@article{van_boven_feeling_2010,
	title = {Feeling close: {Emotional} intensity reduces perceived psychological distance: {Journal} of {Personality} and {Social} {Psychology}},
	volume = {98},
	issn = {0022-3514},
	shorttitle = {Feeling close},
	url = {https://ucd.idm.oclc.org/login?url=https://search.ebscohost.com/login.aspx?direct=true&db=pdh&AN=2010-09990-002&site=ehost-live&scope=site},
	doi = {10.1037/a0019262},
	abstract = {The results of 6 experiments indicate that emotional intensity reduces perceived psychological distance. People who described events emotionally rather than neutrally perceived those events as less psychologically distant, including embarrassing autobiographical events (Experiment 1), past and future dentist visits (Experiment 2), positive and negative events (Experiment 3), and a national tragedy (Experiment 6). People also perceived an event (dancing in front of an audience) as less psychologically distant when they were in a more emotionally arousing social role (of performer) than in a less emotionally arousing social role (of observer; Experiment 4). Two findings bolster the causal role of emotional intensity in reducing perceived psychological distance. First, reported emotional intensity was negatively correlated with perceived psychological distance and statistically mediated the effect of being in an emotionally arousing social role on perceived psychological distance (Experiment 4). Second, providing people with an alternative interpretation of their emotions (emotionally ambiguous whale songs) significantly reduced, even reversed, the negative correlation between self-reported emotional intensity and perceived psychological distance (Experiment 5). These findings about emotional intensity are consistent with the broader idea that perceived psychological distance is grounded in and influenced by the phenomenology of objective distance. Implications for theories of psychological distance, emotionality, and choice are discussed. (PsycInfo Database Record (c) 2023 APA, all rights reserved)},
	number = {6},
	urldate = {2024-04-21},
	journal = {Journal of Personality and Social Psychology},
	publisher = {American Psychological Association},
	author = {Van Boven, Leaf and Kane, Joanne and McGraw, A. Peter and Dale, Jeannette},
	month = jun,
	year = {2010},
	keywords = {Emotions, psychological distance, Female, Humans, Male, Young Adult, Intuition, Judgment, emotion, Psychological Distance, judgment, Social Distance, Adolescent, Arousal, Dental Care, Emotional States, Emotionality (Personality), intensity, Intention, Life Change Events, Mental Recall, Pilot Projects, Role, Self Disclosure, Social Environment, Social Identification, Students, subjective time, Time Perception},
	pages = {872--885},
	file = {Van Boven et al_2010_Feeling close.pdf:/Users/lorcanmclaren/Library/CloudStorage/GoogleDrive-lorcan.mclaren@ucdconnect.ie/My Drive/Zotero/Van Boven et al_2010_Feeling close.pdf:application/pdf},
}

@article{mcdonald_personal_2015,
	title = {Personal experience and the ‘psychological distance’ of climate change: {An} integrative review},
	volume = {44},
	issn = {0272-4944},
	shorttitle = {Personal experience and the ‘psychological distance’ of climate change},
	url = {https://www.sciencedirect.com/science/article/pii/S0272494415300396},
	doi = {10.1016/j.jenvp.2015.10.003},
	abstract = {Studies examining personal experiences of climate change-related events highlight the potential to encourage climate action by framing it as happening now, in your neighborhood, and affecting people like you – that is, psychologically close. We compare this literature to studies that examine psychological distance. The review reveals a disconnect: while studies of personal experience suggest merits of reducing psychological distance, other studies present a more nuanced picture in which psychological proximity does not always lead to more concern about or action on climate change. Despite its emphasis, psychological distance has not been widely studied in experimental work in the climate change context, and there is a need for more systematic examination of its effects across a range of mitigation and adaptation actions. Further, our review identifies potential pitfalls associated with decreasing psychological distance, such as fear and avoidance. Finally, we provide preliminary recommendations for optimal ways to bring climate change “home.”},
	urldate = {2024-04-21},
	journal = {Journal of Environmental Psychology},
	author = {McDonald, Rachel I. and Chai, Hui Yi and Newell, Ben R.},
	month = dec,
	year = {2015},
	keywords = {Climate change, Psychological distance, Adaptation, Mitigation, Personal experience},
	pages = {109--118},
	file = {McDonald et al_2015_Personal experience and the ‘psychological distance’ of climate change.pdf:/Users/lorcanmclaren/Library/CloudStorage/GoogleDrive-lorcan.mclaren@ucdconnect.ie/My Drive/Zotero/McDonald et al_2015_Personal experience and the ‘psychological distance’ of climate change.pdf:application/pdf;ScienceDirect Snapshot:/Users/lorcanmclaren/Zotero/storage/7Q5QRTL9/S0272494415300396.html:text/html},
}

@article{davis_psychological_2011,
	title = {Psychological distance and emotional experience: {What} you see is what you get: {Emotion}},
	volume = {11},
	issn = {1528-3542},
	shorttitle = {Psychological distance and emotional experience},
	url = {https://ucd.idm.oclc.org/login?url=https://search.ebscohost.com/login.aspx?direct=true&db=pdh&AN=2011-07236-023&site=ehost-live&scope=site},
	doi = {10.1037/a0021783},
	abstract = {Recent research suggests that perceiving negative emotion-eliciting scenes approaching intensifies the associated felt emotion, while perceiving emotion-eliciting scenes receding weakens the associated felt emotion (Muhlberger, Neumann, Wieser, \& Pauli, 2008). In the present studies, we sought to extend these findings by examining the effects of imagining rather than perceiving such changes to negative emotion-eliciting scenes. Across three studies, we found that negative scenes generally elicited less negative responses and lower levels of arousal when imagined moving away from participants and shrinking, and more negative responses and higher levels of arousal when imagined moving toward participants and growing, as compared to the responses elicited by negative scenes when imagined unchanged. Patterns in responses to neutral scenes undergoing the same imagined transformations were similar on ratings of emotional arousal, but differed on valence—generally eliciting greater positivity when imagined moving toward participants and growing, and less positivity when imagined moving away from participants and shrinking. Moreover, for these effects to emerge, participants reported it necessary to explicitly imagine scenes moving closer or farther. These findings have implications for emotion regulation, and suggest that imagined spatial distance plays a role in mental representations of emotionally salient events. (PsycInfo Database Record (c) 2020 APA, all rights reserved)},
	number = {2},
	urldate = {2024-04-21},
	journal = {Emotion},
	publisher = {American Psychological Association},
	author = {Davis, Joshua Ian and Gross, James J. and Ochsner, Kevin N.},
	month = apr,
	year = {2011},
	keywords = {Emotions, psychological distance, Adult, Female, Humans, Male, Young Adult, Psychological Distance, Arousal, Emotional States, Cognitive Processes, Emotional Regulation, Emotional Responses, Imagery, emotion regulation, emotional experience, Emotional Intelligence, Imagination, mental imagery, mental representation, Photic Stimulation, Social Perception, Space Perception},
	pages = {438--444},
	file = {Davis et al_2011_Psychological distance and emotional experience.pdf:/Users/lorcanmclaren/Library/CloudStorage/GoogleDrive-lorcan.mclaren@ucdconnect.ie/My Drive/Zotero/Davis et al_2011_Psychological distance and emotional experience.pdf:application/pdf},
}

