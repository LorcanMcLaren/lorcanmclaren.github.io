}

@misc{arnold_psychological_2022,
	title = {Psychological {Distance} and {Event} {Construal} {Depend} {Not} {Only} on {Event} {Distance}, but {Also} on {Event} {Resolution}},
	abstract = {Construal level theory states that the psychological distance of events be it temporal, spatial, social or hypothetical affects the level of construal and in consequence downstream attitudes and behaviors.  We show that the event's distance is not the only factor that determines psychological
distance.  An event's resolution affects the psychological distance just the like.  We substantiate our theoretical claims by replicating the BIF task experiment (n = 358) and the open-ended
activity descriptions (n = 357) from Liberman and Trope (1998) in an online setting, and the
concreteness and temporal distance in New York Times articles (n = 15,075) from Bhatia and Walasek (2016).  We leave the theoretical core from construal level theory untouched, but show the added value of distinguishing between event distance and event resolution in all experiments. Our insights are particularly relevant for all those who seek to measure levels of construal from language.},
	author = {Arnold, Christian and Bechara, Hannah and Jankin, Slava},
	month = oct,
	year = {2022},
}

