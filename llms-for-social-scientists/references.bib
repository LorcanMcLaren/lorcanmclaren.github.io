@article{skitka_political_2015,
	series = {Sydney symposium of social psychology},
	title = {Political orientation and moral conviction: {A} conservative advantage or an equal opportunity motivator of political engagement?},
	issn = {978-1-138-82968-8 (Paperback); 978-1-138-82967-1 (Hardcover); 978-1-315-71710-4 (Digital (undefined format))},
	abstract = {This chapter seeks to answer three questions: (1) Do conservatives vest their positions on political issues with stronger moral conviction than liberals? (2) Do conservatives see more, rather than fewer, of their political positions as related to morality than liberals? And (3) does moral conviction have different effects on hberals' and conservatives' degrees of political engagement (e.g., intentions to vote, or engagement in activism)? We answer the first question by conducting meta-analyses of the association between political orientation and moral conviction with 42 separate issues and 23 samples; the second question by conducting a meta-analysis of the association between political orientation and individuals' average moral conviction across multiple issues with eight samples; and the third question by conducting a meta-analysis of six samples to find whether political orientation moderates the relationship between moral conviction and political engagement across eight distinct issue domains. Before turning to the details of these analyses, we first provide some background on the concept of moral conviction, and competing hypotheses about the likely relationship between morality and politics. (PsycInfo Database Record (c) 2020 APA, all rights reserved)},
	journal = {Social psychology and politics},
	author = {Skitka, Linda J. and Morgan, G. Scott and Wisneski, Daniel C.},
