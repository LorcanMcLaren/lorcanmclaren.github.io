	file = {Hoover et al_2020_Moral Foundations Twitter Corpus.pdf:/Users/lorcanmclaren/Library/CloudStorage/GoogleDrive-lorcan.mclaren@ucdconnect.ie/My Drive/Zotero/Hoover et al_2020_Moral Foundations Twitter Corpus.pdf:application/pdf},
}

