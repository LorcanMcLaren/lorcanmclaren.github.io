}

@article{felli_managing_2013,
	title = {Managing {Climate} {Insecurity} by {Ensuring} {Continuous} {Capital} {Accumulation}: '{Climate} {Refugees}' and '{Climate} {Migrants}'},
	volume = {18},
	issn = {13563467},
