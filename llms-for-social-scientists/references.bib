@article{goertz_concepts_2012,
	title = {Concepts and measurement: {Ontology} and epistemology},
	volume = {51},
	issn = {0539-0184},
	shorttitle = {Concepts and measurement},
	url = {https://doi.org/10.1177/0539018412437108},
	doi = {10.1177/0539018412437108},
	abstract = {This article discusses some ontological and epistemological differences in qualitative and quantitative approaches to concepts and measurement. Concept formation inevitably raises the issue of ontology because it involves specifying what is inherent and important in the empirical phenomenon represented by a concept, e.g. ‘What is democracy?’ Qualitative researchers adopt a semantic approach and work hard to identify the intrinsic necessary defining attributes of a concept. Quantitative scholars adopt an indicator-latent variable approach and seek to identify good indicators that are caused by the latent variable. Concepts and measurement also raise epistemological issues about the nature and quality of knowledge. In quantitative analyses, the challenges of knowledge generation are closely linked to ‘error’, understood as the difference between an estimated value and a true value. By contrast, in qualitative analyses the challenges of knowledge generation are more closely linked to ‘fuzziness’, understood as partial membership in a conceptual set.},
	language = {en},
	number = {2},
	urldate = {2024-03-25},
	journal = {Social Science Information},
	publisher = {SAGE Publications Ltd},
	author = {Goertz, Gary and Mahoney, James},
