@article{lenzi_deliberating_2019,
	title = {Deliberating about {Climate} {Change}: {The} {Case} for ‘{Thinking} and {Nudging}’},
	volume = {6},
	copyright = {© 2019 Walter de Gruyter GmbH, Berlin/Boston},
	issn = {21945616},
	shorttitle = {Deliberating about {Climate} {Change}},
	url = {https://www.proquest.com/docview/2349147791/abstract/FCC6E6BE4E8E4B9DPQ/1},
	doi = {10.1515/mopp-2018-0034},
	abstract = {Proponents of deliberative democracy believe deliberation provides the best chance of finding effective and legitimate climate policies. However, in many societies there is substantial evidence of biased cognition and polarisation about climate change. Further, many appear unable to distinguish reliable scientific information from false claims or misinformation. While deliberation significantly reduces polarisation about climate change, and can even increase the provision of reliable beliefs, these benefits are difficult to scale up, and are slow to affect whole societies. In response, I propose a combined strategy of ‘thinking and nudging’. While deliberative theorists tend to view nudging askance, combining deliberation with nudges promises to be a timelier and more effective response to climate change than deliberation alone. I outline several proposals to improve societal deliberative capacity while reducing climate risks, including media reform, strategic communication and framing of debates, incentivising pro-climate behaviour change, and better education about science.},
	language = {English},
	number = {2},
	urldate = {2024-07-23},
	journal = {Moral Philosophy and Politics},
	publisher = {Walter de Gruyter GmbH},
	author = {Lenzi, Dominic},
	year = {2019},
	note = {Num Pages: 313-336
Place: Berlin, Germany},
	keywords = {climate change, Climate change, deliberative democracy, Deliberative democracy, Read, climate skepticism, cultural cognition, nudge, Nudge, Polarization, Thought},
	pages = {313--336},
	file = {Lenzi_2019_Deliberating about Climate Change.pdf:/Users/lorcanmclaren/Library/CloudStorage/GoogleDrive-lorcan.mclaren@ucdconnect.ie/My Drive/Zotero/Lenzi_2019_Deliberating about Climate Change.pdf:application/pdf},
}

@article{walter_who_2023,
	title = {Who talks to whom? {Using} social network models to understand debate networks in the {European} {Parliament}},
	volume = {24},
	issn = {1465-1165},
	shorttitle = {Who talks to whom?},
	url = {https://doi.org/10.1177/14651165221137994},
	doi = {10.1177/14651165221137994},
	abstract = {Research into parliamentary speech making–behaviour of Members of the European Parliament (MEPs) usually takes a static perspective. We offer an interactive and dynamic approach that understands parliamentary debates as a relational network phenomenon and investigates MEPs’ debate interactions. This allows us to uncover dynamics of inclusiveness and pluralism, self-reinforcing power relationships and transnational policy alliances. Analyzing 11,408 debate interactions between MEPs using a combination of text and dynamic network analysis, we find that male, senior and influential parliamentarians from powerful member states receive more attention with evidence for a self-reinforcing effect over time. Interestingly, seniority matters more for debate attention than leadership positions. Sharing the same nationality and a similar political leaning also shape debate coalitions with the former being more important than the latter.},
	language = {en},
	number = {2},
	urldate = {2024-07-23},
	journal = {European Union Politics},
	publisher = {SAGE Publications},
	author = {Walter, Stefanie and Kinski, Lucy and Boda, Zsófia},
	month = jun,
	year = {2023},
	keywords = {Read},
	pages = {410--423},
	file = {Walter et al_2023_Who talks to whom.pdf:/Users/lorcanmclaren/Library/CloudStorage/GoogleDrive-lorcan.mclaren@ucdconnect.ie/My Drive/Zotero/Walter et al_2023_Who talks to whom.pdf:application/pdf},
}

@article{debus_manifestation_2021,
	title = {The manifestation of the green agenda: a comparative analysis of parliamentary debates},
	volume = {30},
	issn = {0964-4016},
	shorttitle = {The manifestation of the green agenda},
	url = {https://doi.org/10.1080/09644016.2020.1864130},
	doi = {10.1080/09644016.2020.1864130},
	abstract = {Parliamentary debates are an important instrument for setting the political agenda. We hypothesize that parliamentarians belonging to a Green party deliver more speeches on issues related not only to the environment, but also to agriculture, energy and transport as well as to citizen and minority rights. We conceptualize this mix of policy issues as the green agenda. Research on the programmatic-ideological position of political parties has shown that such a broader green agenda exists. Can we also observe this green agenda in parliamentary debates? Does the manifestation of the green agenda depend on the representation of political groups in parliament? By drawing on original data for parliamentary debates in the Czech Republic, Finland, Germany, Ireland, and Sweden, we show that Green parties in parliament push forward issues related to the broader green agenda, though it is also affected by the representation of Agrarian parties.},
	number = {6},
	urldate = {2024-07-23},
	journal = {Environmental Politics},
	publisher = {Routledge},
	author = {Debus, Marc and Tosun, Jale},
	month = sep,
	year = {2021},
	note = {\_eprint: https://doi.org/10.1080/09644016.2020.1864130},
	keywords = {Green parties, party competition, Read, comparative analysis, green agenda, issue ownership, parliamentary speeches},
	pages = {918--937},
	file = {Debus_Tosun_2021_The manifestation of the green agenda.pdf:/Users/lorcanmclaren/Library/CloudStorage/GoogleDrive-lorcan.mclaren@ucdconnect.ie/My Drive/Zotero/Debus_Tosun_2021_The manifestation of the green agenda.pdf:application/pdf},
}

@article{sanchez_salgado_emotions_2021-1,
