@article{burns_eu_2020,
	title = {{EU} environmental policy in times of crisis},
	volume = {27},
	issn = {1350-1763},
	url = {https://doi.org/10.1080/13501763.2018.1561741},
	doi = {10.1080/13501763.2018.1561741},
	abstract = {The European Union (EU) has been buffeted by a range of crises since 2007, not least the economic and financial crisis. One potential victim of this economic malaise is environmental policy ambition. It is well-established that during economic crises environmental policy slips down the agenda with long term consequences for environmental quality. The EU has sought to cast itself as a global environmental leader but that leadership has in large part rested upon its ability to set ambitious policy goals at home. The future environmental policy trajectory and leadership of the EU may be under threat as the Union struggles to emerge from the economic crisis. This article presents a comprehensive and robust analysis of all environmental policy outputs adopted by the EU over a ten-year period covering the crisis. This legislative analysis is supplemented by interviews with policy stakeholders. The article finds evidence of waning ambition over the period under analysis but a range of explanatory variables emerges from the interviews, which suggests that the diminution in EU environmental policy ambition is driven by a mix of factors and maybe likely to persist over the longer term.},
	number = {1},
	urldate = {2025-02-14},
	journal = {Journal of European Public Policy},
	publisher = {Routledge},
	author = {Burns, Charlotte and Eckersley, Peter and Tobin, Paul},
	month = jan,
	year = {2020},
	note = {\_eprint: https://doi.org/10.1080/13501763.2018.1561741},
	pages = {1--19},
	file = {Burns et al. - 2020 - EU environmental policy in times of crisis.pdf:/Users/lorcanmclaren/Library/CloudStorage/GoogleDrive-lorcan.mclaren@ucdconnect.ie/My Drive/Zotero/Burns et al. - 2020 - EU environmental policy in times of crisis.pdf:application/pdf},
}

